{
  "name": "Élevé AI",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "npm install",
  "postStartCommand": "npm start",
  "forwardPorts": [3001],
  "portsAttributes": {
    "3001": {
      "label": "Élevé AI App",
      "onAutoForward": "openBrowserOnce",
      "visibility": "private"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
